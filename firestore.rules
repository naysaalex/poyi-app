rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()      { return request.auth != null; }
    function isOwner(uid)    { return request.auth.uid == uid; }
    function isCollab(board) { return request.auth.uid in board.data.collaborators; }

    // Get the owner's user profile for a board
    function ownerOf(boardData) {
      return get(/databases/$(database)/documents/users/$(boardData.ownerId)).data;
    }

    // Board visibility matrix:
    //   private   → owner (collaborators) only
    //   friends   → owner + mutual follows (friendIds) only
    //   followers → owner + followers + friends
    //   public    → all signed-in users
    function canReadBoard(board) {
      let p    = board.data.privacy;
      let uid  = request.auth.uid;
      let own  = ownerOf(board.data);
      return isCollab(board)
          || p == 'public'
          || (p == 'followers' && (uid in own.followerIds || uid in own.friendIds))
          || (p == 'friends'   &&  uid in own.friendIds);
    }

    // Same check but takes boardId (for subcollection reads)
    function canReadBoardById(boardId) {
      let b   = get(/databases/$(database)/documents/boards/$(boardId));
      let p   = b.data.privacy;
      let uid = request.auth.uid;
      let own = get(/databases/$(database)/documents/users/$(b.data.ownerId)).data;
      return request.auth.uid in b.data.collaborators
          || p == 'public'
          || (p == 'followers' && (uid in own.followerIds || uid in own.friendIds))
          || (p == 'friends'   &&  uid in own.friendIds);
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if signedIn() && isOwner(uid);
      allow delete: if signedIn() && isOwner(uid);
      allow update: if signedIn() && (
        isOwner(uid) ||
        // Any signed-in user may update only follow-related arrays on others
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followerIds', 'followingIds', 'friendIds', 'friendCount'])
      );
    }

    match /friendRequests/{id} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }

    match /followRequests/{id} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && (
        resource.data.to   == request.auth.uid ||
        resource.data.from == request.auth.uid
      );
    }

    match /notifications/{id} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      // Recipient can delete their own notifications.
      // Sender (fromUid) can also delete — needed for board invite cancellation.
      allow delete: if signedIn() && (
        resource.data.userId  == request.auth.uid ||
        resource.data.fromUid == request.auth.uid
      );
    }

    match /boards/{boardId} {
      allow read:   if signedIn() && canReadBoard(resource);
      allow create: if signedIn();
      allow update: if signedIn() && (
        // Collaborators can update board content
        isCollab(resource) ||
        // An invited user can accept: adds self to collaborators, removes self from pendingInvites
        (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['collaborators', 'pendingInvites'])
          && request.auth.uid in request.resource.data.collaborators
          && !(request.auth.uid in resource.data.collaborators)) ||
        // A collaborator can leave: removes self from collaborators only
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collaborators'])
          && request.auth.uid in resource.data.collaborators
          && !(request.auth.uid in request.resource.data.collaborators)
          && request.auth.uid != resource.data.ownerId) ||
        // Owner can update pendingInvites and updatedAt (when inviting or cancelling)
        (resource.data.ownerId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['pendingInvites', 'updatedAt']))
      );
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /places/{placeId} {
        allow read:  if signedIn() && canReadBoardById(boardId);
        allow write: if signedIn() && request.auth.uid in
          get(/databases/$(database)/documents/boards/$(boardId)).data.collaborators;
      }

      match /visionImages/{imgId} {
        allow read:   if signedIn() && canReadBoardById(boardId);
        allow create: if signedIn() && request.auth.uid in
          get(/databases/$(database)/documents/boards/$(boardId)).data.collaborators;
        allow delete: if signedIn() && (
          resource.data.addedBy == request.auth.uid ||
          get(/databases/$(database)/documents/boards/$(boardId)).data.ownerId == request.auth.uid
        );
      }
    }

    match /discoverImages/{id} {
      allow read:  if signedIn();
      allow write: if false;
    }
  }
}
